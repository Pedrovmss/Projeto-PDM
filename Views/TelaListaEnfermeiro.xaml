<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appProvaA1Enfermeiro.Views.TelaListaEnfermeiro"
             Title="Lista de Enfermeiros">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Incluir"
                     IconImageSource="iconincluirenfermeiro.png"
                     Clicked="irTelaIncluirEnfermeiro" />
    </ContentPage.ToolbarItems>

    <StackLayout Padding="10">

        <Image Source="fundoenfermeiro.png"
               HeightRequest="100"
               Aspect="AspectFit"
               HorizontalOptions="Center" />

        <SearchBar x:Name="txtBusca"
                   Placeholder="Qual o Enfermeiro?"
                   TextChanged="txtBuscar" />

        <ListView x:Name="lstEnfermeiros"
                  IsPullToRefreshEnabled="True"
                  Refreshing="refCarregando"
                  ItemSelected="lstEnfermeirosItemSelected"
                  HasUnevenRows="True">

            <ListView.Header>
                <Grid ColumnDefinitions="0.6*,1.2*,1.2*,1.6*" Padding="5">
                    <Label Grid.Column="0" Text="ID" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="1" Text="Nome" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="2" Text="Especialidade" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Grid.Column="3" Text="Ações" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid ColumnDefinitions="0.6*,1.2*,1.2*,1.6*" Padding="5">

                            <Label Grid.Column="0"
                                   Text="{Binding enfID}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />

                            <Label Grid.Column="1"
                                   Text="{Binding enfNome}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />

                            <Label Grid.Column="2"
                                   Text="{Binding enfEspecialidade}"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />

                            <HorizontalStackLayout Grid.Column="3"
                                                   Spacing="5"
                                                   HorizontalOptions="Center">

                                <Button Text="Alterar"
                                        FontSize="11"
                                        Padding="6,2"
                                        Clicked="alterarEnfermeiro"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Excluir"
                                        FontSize="11"
                                        Padding="6,2"
                                        Clicked="excluirEnfermeiro"
                                        CommandParameter="{Binding .}" />

                            </HorizontalStackLayout>

                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

    </StackLayout>
</ContentPage>