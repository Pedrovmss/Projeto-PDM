<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="appProvaA1Enfermeiro.Views.TelaListaEnfermeiro"
             BackgroundImageSource="fundoenfermeiro.png"
             Title="Lista de Enfermeiros">

    <!-- Barra de Menu com o método para Incluir uma Nova Enfermeiro -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Incluir" IconImageSource="iconincluirenfermeiro.png" Clicked="irTelaIncluirEnfermeiro" />
    </ContentPage.ToolbarItems>
    <ContentPage.Content>
        <StackLayout>
            <!-- Campo de Busca(Pesquisa) -->
            <SearchBar x:Name="txtBusca" Margin="-10, 0, 0, 0" Placeholder="Qual o Enfermeiro?" TextChanged="txtBuscar" />
            <!-- Limpando a tela quando for feita a pesquisa -->
            <ListView x:Name="lstEnfermeiros" IsPullToRefreshEnabled="True" Refreshing="refCarregando" ItemSelected="lstEnfermeirosItemSelected">
                <!-- Criando as colunas da tabela, os cabeçalhos  -->
                <ListView.Header>
                    <Grid RowDefinitions="Auto" ColumnDefinitions="*, *, *">
                        <Label Grid.Row="0" Grid.Column="0" Text="Código(ID)" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                        <Label Grid.Row="0" Grid.Column="1" Text="Nome" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                        <Label Grid.Row="0" Grid.Column="2" Text="Especialidade" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                    </Grid>
                </ListView.Header>
                <!-- Criando as linhas de detalhes, mostra o conteúdo dos atributos da Tabela Enfermeiro  -->
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <!-- Menu de contexto, método para Excluir uma Enfermeiro  -->
                            <ViewCell.ContextActions>
                                <MenuItem Text="Excluir Enfermeiro" IconImageSource="iconexcluirenfermeiro.png" Clicked="excluirEnfermeiro" />
                            </ViewCell.ContextActions>
                            <Grid RowDefinitions="Auto" ColumnDefinitions="*, *, *">
                                <Label Grid.Row="0" Grid.Column="0" Text="{Binding enfID}" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                                <Label Grid.Row="0" Grid.Column="1" Text="{Binding enfNome}" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                                <Label Grid.Row="0" Grid.Column="2" Text="{Binding enfEspecialidade}" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>